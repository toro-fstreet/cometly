# Environment Variables for Cometly Report Generation

# Meta Ads API Access Token
# Get from: https://developers.facebook.com/tools/explorer/
COMETLY_ACCESS_TOKEN=your_meta_access_token_here

# GitHub Personal Access Token  
# Get from: https://github.com/settings/tokens
# Needs 'repo' scope for push access
GITHUB_TOKEN=your_github_token_here

# Optional: Slack webhook for notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK